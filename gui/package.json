{
  "name": "songcut-gui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron:build": "tsc -p tsconfig.electron.json",
    "electron:dev": "tsc -p tsconfig.electron.json && electron .",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.node.json && tsc -p tsconfig.electron.json --noEmit && vite build && tsc -p tsconfig.electron.json",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.node.json && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.2.1",
    "i18next": "^26.3.6",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.10",
    "tailwind-merge": "^2.5.5",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
